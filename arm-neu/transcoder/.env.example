# ARM Transcoder Environment Configuration
# Copy this file to .env and customize for your environment

# ========== TIMEZONE ==========
TZ=America/New_York

# ========== USER/GROUP IDS ==========
# The transcoder process runs as this UID/GID inside the container.
# Set these to match your ARM container's ARM_UID/ARM_GID so that
# NFS-shared files (raw, completed) have consistent ownership.
# Default: 1000:1000 (matches ARM's default arm user)
TRANSCODER_UID=1000
TRANSCODER_GID=1000

# ========== SHARED STORAGE PATHS ==========
# Host paths to shared storage (NFS, SMB/CIFS, local mount, etc.)
# These are mounted into the container as /data/raw and /data/completed
HOST_RAW_PATH=/mnt/media/raw
HOST_COMPLETED_PATH=/mnt/media/completed

# ========== LOCAL PATHS ==========
# Working directory for transcoding (local SSD recommended for speed)
WORK_PATH=./work

# Database storage (host directory mounted to /data/db in container)
DB_PATH=./data

# Presets directory
PRESET_PATH=./presets

# Log file directory (host directory mounted to /data/logs in container)
LOG_PATH=./logs

# ========== AUTHENTICATION ==========
# Require API key for all endpoints (except webhook if WEBHOOK_SECRET is set)
REQUIRE_API_AUTH=false

# API keys (comma-separated)
# Format: "key1,key2,key3" or "admin:key1,readonly:key2"
# Example: API_KEYS=admin:abc123,readonly:def456
API_KEYS=

# ========== WEBHOOK ==========
# Port for webhook receiver
WEBHOOK_PORT=5000

# Webhook secret for ARM callbacks (X-Webhook-Secret header)
WEBHOOK_SECRET=

# ARM callback URL - transcoder notifies ARM when jobs complete/fail.
# Same machine (Docker network): http://arm-rippers:8080
# Remote ARM server: http://<arm-ip>:8080
# Leave empty to disable callbacks (jobs will stay at "waiting_transcode").
ARM_CALLBACK_URL=http://arm-rippers:8080

# ========== TRANSCODING ==========
# Preset and encoding settings are configured via the /api/v1/presets API
# (not env vars). The UI's settings page provides a visual preset editor.
# Scheme is auto-detected from GPU_VENDOR (nvidia/intel/amd/"" for software).

# ========== AMD GPU (VAAPI) ==========
# VAAPI render device path (only needed for AMD/Intel VAAPI encoding)
# VAAPI_DEVICE=/dev/dri/renderD128

# ========== FILE HANDLING ==========
# Delete source files after successful transcode
DELETE_SOURCE=true

# Output file extension
OUTPUT_EXTENSION=mkv

# Output organization is now driven entirely by ARM via the webhook
# output_path field. The transcoder appends payload.output_path to
# COMPLETED_PATH and writes there - no per-type subdir env vars.
# Set MOVIES_SUBDIR / TV_SUBDIR / AUDIO_SUBDIR / UNIDENTIFIED_SUBDIR on
# the ARM ripper host instead (they feed into Job.type_subfolder which
# ARM ships in the webhook).

# ========== PERFORMANCE ==========
# Max concurrent transcodes (1 for single GPU)
MAX_CONCURRENT=1

# Seconds to wait for source folder to stabilize before transcoding
STABILIZE_SECONDS=60

# ========== DISK SPACE ==========
# Minimum free disk space required before starting a transcode (GB)
MINIMUM_FREE_SPACE_GB=10

# ========== RETRY ==========
# Maximum retry attempts for failed jobs (0-10)
MAX_RETRY_COUNT=3

# ========== LOGGING ==========
LOG_LEVEL=INFO

# Log level for third-party libraries (aiosqlite, httpcore, httpx, uvicorn.access)
LOG_LEVEL_LIBRARIES=WARNING

# ========== VERSION PINNING ==========
# Pin to a specific release (e.g. 13.0.0) or use "latest"
TRANSCODER_VERSION=latest

# ========== ARM RIPPER (if running alongside) ==========
# Uncomment the arm-rippers service in docker-compose.yml to use these
ARM_PORT=8080
ARM_LOGS_PATH=/mnt/arm/logs
ARM_CONFIG_PATH=/mnt/arm/config
ARM_MUSIC_PATH=/mnt/music/Import
ARM_CPUSET=3
